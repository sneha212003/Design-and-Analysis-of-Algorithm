import time

def function(txt, pat, m, n):

    # Traverse through the text
    for i in range(m - n + 1):

        # Compare substring with pattern
        if txt[i:n+i] == pat:
            return i

    return -1


# User input
txt = input("Enter a text : ")
pat = input("Enter a pattern : ")

# Start time
stime = time.time()

# Function call
result = function(txt, pat, len(txt), len(pat))

# End time
etime = time.time()

# Output
if result != -1:
    print("Pattern found at index:", result)
else:
    print("Pattern not found")

# Execution time
print("Execution Time:", etime - stime)
